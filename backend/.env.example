# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/taskmanagement
# For MongoDB Atlas, use this format:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/taskmanagement?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Change these in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars_12345678
JWT_EXPIRE=7d

# Cookie Configuration
COOKIE_EXPIRE=7

# AES Encryption Key (Must be exactly 32 characters)
# IMPORTANT: Change this in production!
ENCRYPTION_KEY=change_me_32_character_key_!!!!

# CORS Configuration
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
